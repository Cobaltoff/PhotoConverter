<Window x:Class="PhotoConverterV2.Dialogs.WatermarkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎨 Watermark Settings"
        Width="420" Height="660"
        MinWidth="380" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Satır 1: Toggle + Kapsam -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ToggleButton x:Name="BtnWatermarkEnabled"
                          Grid.Column="0" Height="30" Padding="12,0"
                          Checked="WatermarkEnabled_Changed"
                          Unchecked="WatermarkEnabled_Changed">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#0078d4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#0078d4"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ToggleButton.Style>
                <TextBlock x:Name="LblAktif" Text="Aktif" FontSize="13"/>
            </ToggleButton>
            <ComboBox x:Name="CboWatermarkScope"
                      Grid.Column="2" Height="30"
                      SelectedIndex="0"
                      SelectionChanged="WatermarkScope_Changed">
                <ComboBoxItem Content="Tüm fotoğraflar"/>
                <ComboBoxItem Content="Seçili fotoğraf"/>
            </ComboBox>
        </Grid>

        <!-- Satır 2: Preset seç / yeni / kaydet / sil -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CboWatermarkPreset"
                      Grid.Column="0" Height="30"
                      SelectionChanged="CboWatermarkPreset_SelectionChanged"/>
            <Button Grid.Column="2" Content="+" Height="30" Width="30"
                    Padding="0" FontSize="16"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    ToolTip="Yeni preset"
                    Click="BtnNewWatermark_Click"/>
            <Button Grid.Column="4" Content="💾" Height="30" Width="30"
                    Padding="0" FontFamily="Segoe UI Emoji"
                    Background="{DynamicResource InputBgBrush}"
                    Foreground="{DynamicResource ForegroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    ToolTip="Kaydet"
                    Click="BtnSaveWatermark_Click"/>
            <Button Grid.Column="6" Content="🗑" Height="30" Width="30"
                    Padding="0" FontFamily="Segoe UI Emoji"
                    Background="#e53935" Foreground="White" BorderThickness="0"
                    ToolTip="Sil"
                    Click="BtnDeleteWatermark_Click"/>
        </Grid>

        <!-- Satır 3: Preset adı düzenle -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LblAd" Text="Ad:" VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundBrush}"
                       FontSize="12" Margin="0,0,4,0"/>
            <TextBox x:Name="TxtPresetName" Grid.Column="2" Height="30"
                     Background="{DynamicResource InputBgBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     BorderBrush="{DynamicResource BorderBrush2}"
                     TextChanged="TxtPresetName_Changed"/>
        </Grid>

        <!-- Satır 4: Ayarlar ScrollViewer -->
        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Separator Margin="0,4,0,8" Background="{DynamicResource BorderBrush2}"/>

                <!-- METİN -->
                <TextBlock x:Name="LblMetin" Text="Metin" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtWmText" Height="30" Margin="0,0,0,8"
                         Background="{DynamicResource InputBgBrush}"
                         Foreground="{DynamicResource ForegroundBrush}"
                         BorderBrush="{DynamicResource BorderBrush2}"
                         TextChanged="WmField_Changed"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblOpaklık" Text="Opaklık" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmTextOpacity" Minimum="0" Maximum="1" Value="0.7"
                                ValueChanged="WmField_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblBoyut" Text="Boyut (pt)" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmFontSize" Minimum="8" Maximum="120" Value="24"
                                ValueChanged="WmField_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock x:Name="LblRenk" Text="Renk (#HEX)" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <TextBox x:Name="TxtWmColor" Text="#FFFFFF" Height="26"
                                 Background="{DynamicResource InputBgBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush2}"
                                 FontSize="11"
                                 TextChanged="WmField_Changed"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,4,0,8" Background="{DynamicResource BorderBrush2}"/>

                <!-- LOGO -->
                <TextBlock x:Name="LblLogo" Text="Logo" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtWmLogoPath" Height="30"
                             Background="{DynamicResource InputBgBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush2}"
                             IsReadOnly="True"/>
                    <Button Grid.Column="2" Content="📁" Height="30" Width="30"
                            Padding="0" FontFamily="Segoe UI Emoji"
                            Background="{DynamicResource InputBgBrush}"
                            Foreground="{DynamicResource ForegroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush2}"
                            ToolTip="Logo seç"
                            Click="BtnWmLogo_Click"/>
                    <Button Grid.Column="4" Content="✕" Height="30" Width="30"
                            Padding="0" FontSize="12"
                            Background="#e53935" Foreground="White" BorderThickness="0"
                            ToolTip="Logo kaldır"
                            Click="BtnWmLogoClear_Click"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblLogoOpaklık" Text="Logo Opaklık" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmLogoOpacity" Minimum="0" Maximum="1" Value="0.7"
                                IsEnabled="False" ValueChanged="WmField_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblLogoOlcek" Text="Logo Ölçek" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmLogoScale" Minimum="0.05" Maximum="0.6" Value="0.2"
                                IsEnabled="False" ValueChanged="WmField_Changed"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,4,0,8" Background="{DynamicResource BorderBrush2}"/>

                <!-- POZİSYON - METİN -->
                <TextBlock x:Name="LblMetinKonumu" Text="Metin Konumu"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblYatayMetin" Text="Yatay (X)" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmPosX" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="WmField_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblDikeyMetin" Text="Dikey (Y)" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmPosY" Minimum="0" Maximum="1" Value="0.85"
                                ValueChanged="WmField_Changed"/>
                    </StackPanel>
                </Grid>

                <!-- POZİSYON - LOGO -->
                <TextBlock x:Name="LblLogoKonumu" Text="Logo Konumu"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblYatayLogo" Text="Yatay (X)" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmLogoPosX" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="WmField_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblDikeyLogo" Text="Dikey (Y)" FontSize="11"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                        <Slider x:Name="SldWmLogoPosY" Minimum="0" Maximum="1" Value="0.85"
                                ValueChanged="WmField_Changed"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>