<Window x:Class="PhotoConverterV2.Dialogs.CropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crop"
        Width="820" Height="620"
        MinWidth="600" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Üst: Bilgi satırı -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="6"
                Padding="12,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="LblInstruction"
                           Grid.Column="0"
                           Text="Click and drag to select crop area"
                           Foreground="{DynamicResource SubtleBrush}"
                           VerticalAlignment="Center" FontSize="12"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblTargetLabel"
                               Text="Target:"
                               Foreground="{DynamicResource SubtleBrush}"
                               FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblTargetSize"
                               Text="1200 × 1200"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="12"/>
                    <TextBlock x:Name="LblSelectionInfo"
                               Text=""
                               Foreground="{DynamicResource ForegroundBrush}"
                               FontSize="12" Margin="16,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Orta: Görüntü + Canvas overlay -->
        <Border Grid.Row="1"
                Background="{DynamicResource ThumbnailBgBrush}"
                BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="6"
                ClipToBounds="True">
            <!-- Grid: Image + Canvas üst üste -->
            <Grid x:Name="ImageContainer">
                <Image x:Name="ImgSource"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <!-- Şeffaf overlay — mouse event'leri yakalar -->
                <Canvas x:Name="CropCanvas"
                        Background="Transparent"
                        Cursor="Cross"
                        MouseLeftButtonDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseUp">

                    <!-- Karartma katmanları (4 kenar) -->
                    <Rectangle x:Name="DimTop"    Fill="#80000000" Canvas.Left="0" Canvas.Top="0"/>
                    <Rectangle x:Name="DimLeft"   Fill="#80000000" Canvas.Left="0"/>
                    <Rectangle x:Name="DimRight"  Fill="#80000000"/>
                    <Rectangle x:Name="DimBottom" Fill="#80000000"/>

                    <!-- Seçim çerçevesi -->
                    <Rectangle x:Name="SelectionRect"
                               Stroke="{DynamicResource AccentBrush}"
                               StrokeThickness="2"
                               Fill="Transparent"
                               Visibility="Collapsed"/>
                </Canvas>
            </Grid>
        </Border>

        <!-- Alt: Butonlar -->
        <Border Grid.Row="2"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource BorderBrush2}"
                BorderThickness="1" CornerRadius="6"
                Padding="12,8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="LblCropHint"
                           Grid.Column="0"
                           Text=""
                           Foreground="{DynamicResource SubtleBrush}"
                           FontSize="11" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnReset"
                            Content="Reset"
                            Height="30" Padding="14,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnReset_Click"/>
                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Height="30" Padding="14,0"
                            Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnApply"
                            Content="✂ Apply Crop"
                            Height="30" Padding="14,0"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Style="{StaticResource StandardButton}"
                            Click="BtnApply_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
