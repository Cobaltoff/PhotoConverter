<Window x:Class="PhotoConverterV2.Dialogs.ProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Platform Profiles"
        Width="640" Height="480"
        MinWidth="540" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="Window_Loaded">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ana içerik: Sol liste + Sağ form -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="185"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SOL: Profil Listesi ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Liste başlığı -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource DropZoneBrush}"
                            CornerRadius="5,5,0,0"
                            Padding="10,8">
                        <TextBlock x:Name="LblProfilesTitle"
                                   Text="Platform Profiles"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </Border>

                    <!-- Profil listesi -->
                    <ListBox x:Name="LstProfiles"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="4"
                             SelectionChanged="LstProfiles_SelectionChanged"/>

                    <!-- + Add butonu -->
                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource BorderBrush2}"
                            BorderThickness="0,1,0,0"
                            Padding="6">
                        <Button x:Name="BtnAdd"
                                Content="+ Add"
                                Height="28"
                                Style="{StaticResource StandardButton}"
                                Click="BtnAdd_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── SAĞ: Profil Detay Formu ── -->
            <Border Grid.Column="2"
                    Background="{DynamicResource PanelBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Form başlık -->
                    <TextBlock x:Name="LblDetailTitle"
                               Grid.Row="0"
                               Text="Profile Details"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0,0,0,14"/>

                    <!-- Form alanları -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Profil Adı -->
                            <TextBlock x:Name="LblNameField"
                                       Text="Profile Name"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtName"
                                     Height="30"
                                     Margin="0,0,0,10"/>

                            <!-- Width / Height -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="LblWidthField"
                                               Text="Width (px)"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,3"/>
                                    <TextBox x:Name="TxtWidth" Height="30"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="LblHeightField"
                                               Text="Height (px)"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,3"/>
                                    <TextBox x:Name="TxtHeight" Height="30"/>
                                </StackPanel>
                            </Grid>

                            <!-- Format -->
                            <TextBlock x:Name="LblFormatField"
                                       Text="Format"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>
                            <ComboBox x:Name="CboFormat"
                                      Height="30"
                                      Margin="0,0,0,10"
                                      SelectionChanged="CboFormat_SelectionChanged">
                                <ComboBoxItem Content="JPEG"/>
                                <ComboBoxItem Content="PNG"/>
                            </ComboBox>

                            <!-- JPEG Quality -->
                            <TextBlock x:Name="LblQualityField"
                                       Text="JPEG Quality (1-100)"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtQuality"
                                     Height="30"
                                     Margin="0,0,0,10"/>

                            <!-- Aspect Ratio Mode -->
                            <TextBlock x:Name="LblAspectField"
                                       Text="Aspect Ratio Mode"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,3"/>
                            <ComboBox x:Name="CboAspect"
                                      Height="30"
                                      Margin="0,0,0,10"
                                      SelectionChanged="CboAspect_SelectionChanged">
                                <ComboBoxItem Content="Crop"/>
                                <ComboBoxItem Content="Pad"/>
                                <ComboBoxItem Content="Stretch"/>
                            </ComboBox>

                            <!-- Pad Color (sadece Pad modunda) -->
                            <StackPanel x:Name="PadColorSection">
                                <TextBlock x:Name="LblPadColorField"
                                           Text="Pad Color"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,3"/>
                                <ComboBox x:Name="CboPadColor"
                                          Height="30"
                                          Margin="0,0,0,10">
                                    <ComboBoxItem Content="White"/>
                                    <ComboBoxItem Content="Black"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Built-in uyarısı -->
                            <Border x:Name="BuiltInWarning"
                                    Background="{DynamicResource DropZoneBrush}"
                                    BorderBrush="{DynamicResource BorderBrush2}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="LblBuiltInWarning"
                                           Text="Built-in profiles cannot be deleted."
                                           Foreground="{DynamicResource SubtleBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Alt butonlar: Delete + Save -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button x:Name="BtnDelete"
                                Content="Delete"
                                Height="32"
                                Padding="14,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnDelete_Click"/>
                        <Button x:Name="BtnSave"
                                Content="Save Profile"
                                Height="32"
                                Padding="14,0"
                                Margin="8,0,0,0"
                                Style="{StaticResource StandardButton}"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Alt kapat butonu -->
        <Button x:Name="BtnClose"
                Grid.Row="1"
                Content="Close"
                Height="32"
                Width="90"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Style="{StaticResource SecondaryButton}"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
